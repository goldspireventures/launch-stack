{
  "name": "goldspire-launch-stack",
  "version": "0.1.0",
  "private": true,
  "description": "Goldspire Launch Stack — internal MVP factory for the Goldspire studio. Reusable, multi-tenant, blueprint-driven launch platform.",
  "license": "UNLICENSED",
  "author": "Goldspire Studio",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel --filter=!@goldspire/dating-mobile",
    "dev:studio": "turbo run dev --parallel --filter=@goldspire/console --filter=@goldspire/goldspire-web --filter=@goldspire/client-portal --filter=@goldspire/dating-web --filter=@goldspire/booking-web --filter=@goldspire/admin",
    "dev:platform": "turbo run dev --parallel --filter=@goldspire/console --filter=@goldspire/goldspire-web --filter=@goldspire/client-portal --filter=@goldspire/dating-web --filter=@goldspire/booking-web --filter=@goldspire/admin --filter=@goldspire/marketplace-web --filter=@goldspire/community-web --filter=@goldspire/ai-agent-web --filter=@goldspire/b2b-saas-web --filter=@goldspire/atlas",
    "dev:mobile": "pnpm --filter @goldspire/dating-mobile dev",
    "dev:marketing": "pnpm --filter @goldspire/goldspire-web dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rimraf node_modules .turbo",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore",
    "db:generate": "pnpm --filter @goldspire/db generate",
    "db:migrate": "pnpm --filter @goldspire/db migrate",
    "db:seed": "pnpm --filter @goldspire/db seed",
    "db:app-role": "node scripts/db/print-app-role-uri.mjs",
    "db:studio": "pnpm --filter @goldspire/db studio",
    "db:reset": "pnpm --filter @goldspire/db reset",
    "smoke:deploy-webhook": "tsx scripts/smoke-studio-deploy-webhook.ts",
    "smoke:golden-paths": "node scripts/smoke-golden-paths.mjs",
    "studio:runbook-alerts": "tsx scripts/studio/runbook-blocker-scan.mjs",
    "studio:stale-enquiry-alerts": "tsx scripts/studio/stale-enquiry-scan.mjs",
    "studio:lab-cron": "tsx scripts/studio/lab-portfolio-cron.mjs",
    "test:e2e": "pnpm --filter @goldspire/e2e exec playwright test",
    "test:e2e:install": "pnpm --filter @goldspire/e2e install:browsers",
    "test:e2e:integration": "pnpm --filter @goldspire/e2e exec playwright test --project=integration",
    "test:e2e:demos": "pnpm --filter @goldspire/e2e exec playwright test --project=demos",
    "test:e2e:heartline": "pnpm --filter @goldspire/e2e exec playwright test --project=heartline",
    "screenshots:heartline": "pnpm --filter @goldspire/e2e run screenshots:heartline",
    "test:e2e:platform": "pnpm --filter @goldspire/e2e exec playwright test --workers=1 --project=platform-full --project=marketing --project=console --project=studio-os --project=platform-v2 --project=integration --project=platform-demo --project=portal",
    "test:e2e:golden": "node scripts/e2e-clean.mjs && pnpm --filter @goldspire/e2e exec playwright test --workers=1 --project=platform-full --project=golden-platform --project=atlas",
    "test:e2e:golden-gate": "node scripts/e2e-golden-gate.mjs",
    "certify:v1": "node scripts/certify-v1.mjs",
    "certify:tier1": "node scripts/certify-tier1-factory.mjs",
    "certify:tier1:offline": "node scripts/certify-tier1-factory.mjs --offline",
    "test:studio-stress": "node scripts/studio-platform-stress.mjs",
    "test:studio-stress:e2e": "node scripts/studio-platform-stress.mjs --e2e-rbac",
    "e2e:clean": "node scripts/e2e-clean.mjs",
    "prep:demo": "node scripts/prep-demo.mjs",
    "test:rls": "pnpm --filter @goldspire/db test:rls",
    "preflight": "node scripts/setup/preflight.mjs",
    "verify:local": "node scripts/setup/verify-local.mjs",
    "prep:testing": "node scripts/prep-testing.mjs",
    "prep:testing:quick": "node scripts/prep-testing.mjs --quick",
    "probe:dev-urls": "tsx scripts/probe-dev-urls.ts",
    "audit:testing": "node scripts/audit-testing.mjs",
    "audit:testing:full": "node scripts/audit-testing.mjs --full",
    "audit:screenshots": "pnpm --filter @goldspire/e2e exec node audit/stack-screenshots.mjs",
    "audit:deal-walkthrough": "pnpm --filter @goldspire/e2e exec node audit/deal-walkthrough.mjs",
    "setup:sync-prod-auth": "node scripts/setup/sync-production-auth.mjs",
    "setup:patch-studio-emails": "tsx scripts/setup/patch-studio-emails.ts",
    "setup:production-smoke": "node scripts/setup/production-smoke.mjs",
    "setup:cleanup-walkthrough": "tsx scripts/setup/cleanup-walkthrough-deals.ts",
    "audit:commercial-sync": "tsx scripts/audit-commercial-sync.mjs",
    "audit:studio-business": "tsx scripts/audit-studio-business.mjs",
    "atlas:reindex": "pnpm --filter @goldspire/knowledge reindex",
    "verify:prod-env": "node scripts/setup/verify-prod-env.mjs",
    "setup": "node scripts/setup/bootstrap.mjs",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@types/node": "^22.7.5",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "dotenv": "^17.4.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.1",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
