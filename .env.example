# ============================================================
# Goldspire Launch Stack — environment variables
# ============================================================
# Copy this file to .env and fill in values for the services
# you want to enable. Every value can be left blank for local
# development — Goldspire falls back to mock providers when keys
# are missing, so you can run the full stack with zero accounts.
# ============================================================

# ---- Core ----
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:4000
NEXT_PUBLIC_CONSOLE_URL=http://localhost:4001
# Public client deal portal (see apps/client-portal). Stripe success URLs land here.
NEXT_PUBLIC_CLIENT_PORTAL_URL=http://localhost:4005
NEXT_PUBLIC_ADMIN_URL=http://localhost:4002
# Goldspire Atlas — internal knowledge portal (RAG)
NEXT_PUBLIC_ATLAS_URL=http://localhost:4016
# Optional — staging Apps grid row + health probe (defaults to NEXT_PUBLIC_ATLAS_URL)
# NEXT_PUBLIC_ATLAS_STAGING_URL=https://atlas.staging.goldspire.studio
NEXT_PUBLIC_GOLDSPIRE_MARKETING_URL=http://localhost:4010
# Catalog live demos — point each at staging when deployed (local ports from README).
NEXT_PUBLIC_HEARTLINE_DEMO_URL=http://localhost:4000
NEXT_PUBLIC_NOVA_CARE_DEMO_URL=http://localhost:4015
NEXT_PUBLIC_BAZAAR_DEMO_URL=http://localhost:4011
NEXT_PUBLIC_SIGNAL_DEMO_URL=http://localhost:4012
NEXT_PUBLIC_LUMEN_DEMO_URL=http://localhost:4013
NEXT_PUBLIC_RELAY_DEMO_URL=http://localhost:4014
# Heartline mobile companion (Expo) — API origin is dating-web
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000
# Optional — shown on contact form success (Calendly, etc.)
# NEXT_PUBLIC_GOLDSPIRE_DISCOVERY_CALL_URL=

# Optional — Studio Console Apps page “Repo” / mobile build links (defaults to public Goldspire repo)
# NEXT_PUBLIC_STUDIO_MONOREPO_URL=https://github.com/your-org/your-repo

# Default tenant slug used by mock auth in dev (matches the seed file).
GOLDSPIRE_TENANT_ID=acme
# Operator tenant row for Console / enquiries / studio profile JSON.
GOLDSPIRE_STUDIO_TENANT_SLUG=goldspire

# ---- Database (Postgres / Supabase) ----
# Used by the app, Drizzle, migrations, and seeds. For Supabase, prefer the
# session pooler URI unless you run Postgres locally.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/goldspire
# Production runtime (RLS-enforced goldspire_app role). Leave unset locally to use DATABASE_URL.
# DATABASE_URL_APP=postgresql://goldspire_app.PROJECT_REF:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres

# ---- Supabase ----
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- Auth provider ----
# Options: mock | supabase | clerk
# 'mock' is intended for local dev only — generates a fixed dev user.
AUTH_PROVIDER=mock
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ---- Payments ----
# Options: mock | stripe
# Local / demos: mock. Production studio deals: stripe + webhooks below.
PAYMENT_PROVIDER=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# When true, enables "Reset for retesting" on studio deal pages (clears paid/processing lines). Never in production.
STUDIO_DEAL_DEV_RESET_ENABLED=
# Mobile in-app purchases (optional, parallel to Stripe)
REVENUECAT_API_KEY=

# ---- Email (transactional) ----
RESEND_API_KEY=
EMAIL_FROM="Goldspire <noreply@goldspire.local>"

# ---- Background jobs ----
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ---- Product analytics + feature flags + session replay ----
POSTHOG_API_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ---- Structured logging (@goldspire/logger) ----
# Service name used in dev log filenames: logs/<LOGGER_SERVICE>-<YYYY-MM-DD>.log
LOGGER_SERVICE=goldspire
# Directory for dev log files (relative to process cwd unless absolute).
LOGGER_LOG_DIR=logs

# ---- Error tracking ----
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ---- Studio Lab (owner portfolio) ----
# Bearer token for Console POST /api/webhooks/venture-revenue (MRR ingest per venture).
# STUDIO_LAB_REVENUE_WEBHOOK_SECRET=
# Bearer for POST /api/webhooks/marketing-lead-inbound (enquiry email replies)
# STUDIO_LEAD_INBOUND_WEBHOOK_SECRET=

# ---- AI providers ----
# Options: mock | openai | anthropic
AI_PROVIDER=mock
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---- Rate limiting (Upstash Redis, optional) ----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- File storage ----
# Supabase Storage uses SUPABASE_* vars above. Override here for R2/S3.
STORAGE_PROVIDER=supabase
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ============================================================
# Production launch (solo-founder) — set on Vercel per app
# ============================================================
# See docs/deployment/solo-founder-operating-guide.md
#
# NODE_ENV=production
# AUTH_PROVIDER=supabase  (or clerk)
# PAYMENT_PROVIDER=stripe
# Replace every localhost URL below with https://… deployed hosts:
#   NEXT_PUBLIC_GOLDSPIRE_MARKETING_URL
#   NEXT_PUBLIC_CONSOLE_URL
#   NEXT_PUBLIC_CLIENT_PORTAL_URL
#   NEXT_PUBLIC_ADMIN_URL
#   NEXT_PUBLIC_HEARTLINE_DEMO_URL
#   NEXT_PUBLIC_NOVA_CARE_DEMO_URL
# Enable studio automation in Console → Configure → Studio:
#   autoIssuePortalOnConvert, autoStampOnKickoff, autoRotateDeployHookOnStamp
