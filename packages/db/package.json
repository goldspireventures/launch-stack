{
  "name": "@goldspire/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts",
    "./tenant-context": "./src/tenant-context.ts",
    "./types": "./src/types.ts"
  },
  "scripts": {
    "lint": "echo 'no lint configured'",
    "typecheck": "tsc --noEmit",
    "generate": "drizzle-kit generate",
    "migrate": "tsx ./scripts/migrate.ts",
    "studio": "drizzle-kit studio",
    "seed": "tsx ./scripts/seed.ts",
    "fixup:heartline": "tsx ./scripts/fixup-heartline.ts",
    "reset": "tsx ./scripts/reset.ts",
    "clean": "rimraf .turbo dist"
  },
  "dependencies": {
    "@goldspire/commercial": "workspace:*",
    "@goldspire/config": "workspace:*",
    "drizzle-orm": "^0.36.0",
    "postgres": "^3.4.4",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.28.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
