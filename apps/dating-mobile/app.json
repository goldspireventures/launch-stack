{
  "expo": {
    "name": "Heartline",
    "slug": "heartline",
    "scheme": "heartline",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "platforms": ["ios", "android", "web"],
    "ios": { "supportsTablet": true, "bundleIdentifier": "studio.goldspire.heartline" },
    "android": { "package": "studio.goldspire.heartline" },
    "web": { "bundler": "metro" },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "http://localhost:4000"
    }
  }
}
